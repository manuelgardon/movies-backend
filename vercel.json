{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [{ "src": "api/index.ts", "use": "@vercel/node", "config": { "includeFiles": ["dist/**"] } }],
  "routes": [{ "src": "/(.*)", "dest": "api/index.ts" }],
  "crons": [
    {
      "path": "/movies/sync",
      "schedule": "0 0 * * *"
    }
  ]
}
